<% title = 'Property Search Results'; headPartial = '../partials/seo/property-list-head'; %>
<link rel="stylesheet" href="/css/property-list.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<!-- Locations data for JavaScript -->
<div id="locations-data" data-locations='<%- JSON.stringify(locations).replace(/'/g, '&#39;') %>' style="display: none;"></div>

<%
  const resultsLocation = [locals.filters?.city, locals.filters?.country].filter(Boolean).join(', ') || 'All locations';
  function buildQueryParams(overrides) {
    const p = { ...(overrides || {}) };
    if (locals.query) p.q = locals.query;
    if (locals.sort && locals.sort !== 'relevance') p.sort = locals.sort;
    if (locals.filters?.country) p.country = locals.filters.country;
    if (locals.filters?.city) p.city = locals.filters.city;
    if (locals.filters?.neighborhood) p.neighborhood = locals.filters.neighborhood;
    if (locals.filters?.min_price) p.min_price = locals.filters.min_price;
    if (locals.filters?.max_price) p.max_price = locals.filters.max_price;
    if (locals.filters?.min_size) p.min_size = locals.filters.min_size;
    if (locals.filters?.max_size) p.max_size = locals.filters.max_size;
    if (locals.filters?.year_built_min) p.year_built_min = locals.filters.year_built_min;
    if (locals.filters?.year_built_max) p.year_built_max = locals.filters.year_built_max;
    if (locals.filters?.bathrooms) p.bathrooms = locals.filters.bathrooms;
    if (locals.filters?.bedrooms?.length) locals.filters.bedrooms.forEach(b => { if (!p.bedrooms) p.bedrooms = []; p.bedrooms.push(b); });
    if (locals.filters?.type?.length) locals.filters.type.forEach(t => { if (!p.type) p.type = []; p.type.push(t); });
    if (locals.filters?.features?.length) locals.filters.features.forEach(f => { if (!p.features) p.features = []; p.features.push(f); });
    if (locals.filters?.status_tags?.length) locals.filters.status_tags.forEach(t => { if (!p.status_tags) p.status_tags = []; p.status_tags.push(t); });
    if (locals.filters?.featured) p.featured = locals.filters.featured;
    if (locals.filters?.new_listing) p.new_listing = locals.filters.new_listing;
    return p;
  }
  function toQueryString(params) {
    const pairs = [];
    Object.entries(params).forEach(([k, v]) => {
      if (v == null || v === '') return;
      if (Array.isArray(v)) v.forEach(vv => pairs.push([k, vv]));
      else pairs.push([k, String(v)]);
    });
    return new URLSearchParams(pairs).toString();
  }
%>
<div class="property-search-page search-results-page">
  <div class="container-wide">
    <!-- Title row: results count + sticky Filters button -->
    <div class="search-results-top">
      <h1 class="search-results-title"><%= totalProperties %> Results in <%= resultsLocation %></h1>
      <button type="button" class="filters-sticky-btn" id="filtersStickyBtn" aria-label="Open filters">
        Filters
      </button>
    </div>

    <!-- Search summary bar (unified horizontal bar with dividers) -->
    <form action="/properties" method="GET" class="search-summary-bar" id="searchSummaryForm">
      <input type="hidden" name="sort" value="<%= locals.sort || 'relevance' %>">
      <div class="search-bar-section">
        <label for="summaryCountry">Location:</label>
        <select id="summaryCountry" name="country" class="search-bar-select">
          <option value="">Any</option>
          <% Object.keys(locations || {}).forEach(c => { %>
            <option value="<%= c %>" <%= locals.filters?.country === c ? 'selected' : '' %>><%= c %></option>
          <% }); %>
        </select>
      </div>
      <div class="search-bar-divider"></div>
      <div class="search-bar-section">
        <label for="summaryOperation">Operation:</label>
        <select id="summaryOperation" name="operation" class="search-bar-select">
          <option value="">Any</option>
          <option value="sale">Buy</option>
          <option value="rent">Rent</option>
        </select>
      </div>
      <div class="search-bar-divider"></div>
      <div class="search-bar-section">
        <label for="summaryType">Type:</label>
        <select id="summaryType" name="type" class="search-bar-select">
          <option value="">Any</option>
          <option value="Apartment" <%= (locals.filters?.type && locals.filters.type.includes('Apartment')) ? 'selected' : '' %>>Apartment</option>
          <option value="House" <%= (locals.filters?.type && locals.filters.type.includes('House')) ? 'selected' : '' %>>House</option>
          <option value="Villa" <%= (locals.filters?.type && locals.filters.type.includes('Villa')) ? 'selected' : '' %>>Villa</option>
          <option value="Land" <%= (locals.filters?.type && locals.filters.type.includes('Land')) ? 'selected' : '' %>>Land</option>
        </select>
      </div>
      <div class="search-bar-divider"></div>
      <button type="submit" class="search-bar-submit">Search</button>
    </form>

    <div class="property-layout property-layout--no-sidebar">
      <!-- Filters in modal (content moved below) -->
      <aside class="filters-sidebar filters-sidebar--modal" id="filtersModal" aria-hidden="true" role="dialog" aria-label="Filters">
        <div class="filters-header">
          <h3>Filters</h3>
          <div class="filters-header-actions">
            <button class="clear-filters" onclick="clearAllFilters()">Clear All</button>
            <button type="button" class="filters-modal-close" id="filtersModalClose" aria-label="Close filters">&times;</button>
          </div>
        </div>
        
        <form id="filtersForm" class="filters-form">
          <!-- Location Filters -->
          <div class="filter-group">
            <h4>Location</h4>
            <div class="form-group">
              <label for="filterCountry">Country</label>
               <select id="filterCountry" name="country" class="form-select">
                <option value="">Any Country</option>
                <% Object.keys(locations).forEach(country => { %>
                  <option value="<%= country %>" <%= locals.filters?.country === country ? 'selected' : '' %>><%= country %></option>
                <% }); %>
              </select>
            </div>
            
            <div class="form-group">
              <label for="filterCity">City</label>
               <select id="filterCity" name="city" class="form-select">
                <option value="">Any City</option>
                <!-- Cities will be populated dynamically -->
              </select>
            </div>
            
            <div class="form-group">
              <label for="filterNeighborhood">Neighborhood</label>
              <select id="filterNeighborhood" name="neighborhood" class="form-select">
                <option value="">Any Neighborhood</option>
                <!-- Neighborhoods will be populated dynamically -->
              </select>
            </div>
          </div>

          <!-- Property Type -->
          <div class="filter-group">
            <h4>Property Type</h4>
            <div class="checkbox-group">
              <label class="checkbox-label">
                <input type="checkbox" name="type" value="Apartment" <%= locals.filters?.type?.includes('Apartment') ? 'checked' : '' %>>
                <span class="checkmark"></span>
                Apartment
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="type" value="House" <%= locals.filters?.type?.includes('House') ? 'checked' : '' %>>
                <span class="checkmark"></span>
                House
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="type" value="Villa" <%= locals.filters?.type?.includes('Villa') ? 'checked' : '' %>>
                <span class="checkmark"></span>
                Villa
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="type" value="Land" <%= locals.filters?.type?.includes('Land') ? 'checked' : '' %>>
                <span class="checkmark"></span>
                Land
              </label>
            </div>
          </div>

          <!-- Price Range -->
          <div class="filter-group">
            <h4>Price Range</h4>
            <div class="price-range">
              <div class="form-group">
                <label for="minPrice">Min Price (€)</label>
                <input type="text" id="minPrice" placeholder="€0" 
                       value="<%= locals.filters?.min_price ? '€' + Number(locals.filters.min_price).toLocaleString() : '' %>" 
                       class="form-input" inputmode="numeric" autocomplete="off">
                <input type="hidden" id="minPriceHidden" name="min_price" value="<%= locals.filters?.min_price || '' %>">
              </div>
              <div class="form-group">
                <label for="maxPrice">Max Price (€)</label>
                <input type="text" id="maxPrice" placeholder="€ Any" 
                       value="<%= locals.filters?.max_price ? '€' + Number(locals.filters.max_price).toLocaleString() : '' %>" 
                       class="form-input" inputmode="numeric" autocomplete="off">
                <input type="hidden" id="maxPriceHidden" name="max_price" value="<%= locals.filters?.max_price || '' %>">
              </div>
            </div>
          </div>

          <!-- Bedrooms & Bathrooms -->
          <div class="filter-group">
            <h4>Bedrooms</h4>
            <div class="checkbox-group">
              <label class="checkbox-label">
                <input type="checkbox" name="bedrooms" value="1" <%= locals.filters?.bedrooms?.includes('1') ? 'checked' : '' %>>
                <span class="checkmark"></span>
                1+
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="bedrooms" value="2" <%= locals.filters?.bedrooms?.includes('2') ? 'checked' : '' %>>
                <span class="checkmark"></span>
                2+
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="bedrooms" value="3" <%= locals.filters?.bedrooms?.includes('3') ? 'checked' : '' %>>
                <span class="checkmark"></span>
                3+
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="bedrooms" value="4" <%= locals.filters?.bedrooms?.includes('4') ? 'checked' : '' %>>
                <span class="checkmark"></span>
                4+
              </label>
            </div>
          </div>

          <!-- Bathrooms -->
          <div class="filter-group">
            <h4>Bathrooms</h4>
            <div class="checkbox-group">
              <label class="checkbox-label">
                <input type="checkbox" name="bathrooms" value="1" <%= locals.filters?.bathrooms === '1' ? 'checked' : '' %>>
                <span class="checkmark"></span>
                1+
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="bathrooms" value="2" <%= locals.filters?.bathrooms === '2' ? 'checked' : '' %>>
                <span class="checkmark"></span>
                2+
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="bathrooms" value="3" <%= locals.filters?.bathrooms === '3' ? 'checked' : '' %>>
                <span class="checkmark"></span>
                3+
              </label>
            </div>
          </div>

          <!-- Size Range -->
          <div class="filter-group">
            <h4>Size Range (m²)</h4>
            <div class="size-range">
              <div class="form-group">
                <label for="minSize">Min Size</label>
                <input type="number" id="minSize" name="min_size" placeholder="0" 
                       value="<%= locals.filters?.min_size || '' %>" class="form-input">
              </div>
              <div class="form-group">
                <label for="maxSize">Max Size</label>
                <input type="number" id="maxSize" name="max_size" placeholder="Any" 
                       value="<%= locals.filters?.max_size || '' %>" class="form-input">
              </div>
            </div>
          </div>

          <!-- Year Built Range -->
          <div class="filter-group">
            <h4>Year Built</h4>
            <div class="year-range">
              <div class="form-group">
                <label for="yearBuiltMin">From Year</label>
                <input type="number" id="yearBuiltMin" name="year_built_min" placeholder="1900" 
                       min="1800" max="<%= new Date().getFullYear() %>"
                       value="<%= locals.filters?.year_built_min || '' %>" class="form-input">
              </div>
              <div class="form-group">
                <label for="yearBuiltMax">To Year</label>
                <input type="number" id="yearBuiltMax" name="year_built_max" placeholder="<%= new Date().getFullYear() %>" 
                       min="1800" max="<%= new Date().getFullYear() %>"
                       value="<%= locals.filters?.year_built_max || '' %>" class="form-input">
              </div>
            </div>
          </div>

          <!-- Status Tags -->
          <div class="filter-group">
            <h4>Status Tag</h4>
            <div class="checkbox-group">
              <label class="checkbox-label">
                <input type="checkbox" name="status_tags" value="New" <%= locals.filters?.status_tags?.includes('New') ? 'checked' : '' %>>
                <span class="checkmark"></span>
                New
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="status_tags" value="Reduced" <%= locals.filters?.status_tags?.includes('Reduced') ? 'checked' : '' %>>
                <span class="checkmark"></span>
                Reduced
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="status_tags" value="Exclusive" <%= locals.filters?.status_tags?.includes('Exclusive') ? 'checked' : '' %>>
                <span class="checkmark"></span>
                Exclusive
              </label>
            </div>
          </div>

          <!-- Property Features -->
          <div class="filter-group">
            <h4>Features</h4>
            <div class="checkbox-group">
              <label class="checkbox-label">
                <input type="checkbox" name="featured" value="true" <%= locals.filters?.featured === 'true' ? 'checked' : '' %>>
                <span class="checkmark"></span>
                Featured Properties
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="new_listing" value="true" <%= locals.filters?.new_listing === 'true' ? 'checked' : '' %>>
                <span class="checkmark"></span>
                New Listings (7 days)
              </label>
              <% (propertyCharacteristics || []).forEach(function(c) { %>
              <label class="checkbox-label">
                <input type="checkbox" name="features" value="<%= c.slug %>" <%= locals.filters?.features?.includes(c.slug) ? 'checked' : '' %>>
                <span class="checkmark"></span>
                <%= c.label %>
              </label>
              <% }) %>
            </div>
          </div>

          <!-- Apply Filters Button -->
          <button type="submit" class="btn btn-primary btn-block">Apply Filters</button>
        </form>
      </aside>
      <div class="filters-modal-backdrop" id="filtersModalBackdrop" aria-hidden="true"></div>

      <!-- Main Content -->
      <main class="property-main">
        <!-- Properties Grid -->
        <div class="properties-container">
          <% if (properties.length > 0) { %>
            <!-- Property Comparison Bar -->
            <div id="comparisonContainer" class="comparison-container" style="display: none;">
              <div class="comparison-header">
                <h3>Properties to Compare</h3>
                <button id="compareBtn" class="btn btn-primary" onclick="showComparisonModal()" disabled>
                  Compare (0)
                </button>
              </div>
              <div id="comparisonList" class="comparison-list">
                <!-- Comparison items will be added here -->
              </div>
            </div>
            
            <div class="properties-grid" id="propertiesGrid">
              <% properties.forEach(property => { %>
                <a href="/properties/<%= property.slug %>" 
                   class="property-card country-<%= property.country.toLowerCase() %>" 
                   data-country="<%= property.country %>"
                   data-property-id="<%= property.id %>"
                   aria-label="View property: <%= property.title %>">
                  
                  <!-- Property Image -->
                  <div class="property-image">
                      <% if (property.photos && property.photos.length > 0) { %>
                        <% if (property.has_variants && property.variant_base) { %>
                          <picture>
                            <source srcset="<%= property.variant_base %>-320.avif 320w, <%= property.variant_base %>-640.avif 640w, <%= property.variant_base %>-960.avif 960w, <%= property.variant_base %>-1280.avif 1280w, <%= property.variant_base %>-1920.avif 1920w" type="image/avif">
                            <source srcset="<%= property.variant_base %>-320.webp 320w, <%= property.variant_base %>-640.webp 640w, <%= property.variant_base %>-960.webp 960w, <%= property.variant_base %>-1280.webp 1280w, <%= property.variant_base %>-1920.webp 1920w" type="image/webp">
                            <img src="<%= property.photos[0] %>" alt="<%= property.title %>"
                                 srcset="<%= property.variant_base %>-320.jpg 320w, <%= property.variant_base %>-640.jpg 640w, <%= property.variant_base %>-960.jpg 960w, <%= property.variant_base %>-1280.jpg 1280w, <%= property.variant_base %>-1920.jpg 1920w"
                                 sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 350px"
                                 loading="lazy" decoding="async"
                                 onerror="this.src='/img/property-placeholder.jpg'">
                          </picture>
                        <% } else { %>
                          <img src="<%= property.photos[0] %>" alt="<%= property.title %>" loading="lazy" decoding="async"
                               onerror="this.src='/img/property-placeholder.jpg'">
                        <% } %>
                    <% } else { %>
                        <img src="/img/property-placeholder.jpg" alt="<%= property.title %>" loading="lazy" decoding="async">
                    <% } %>
                    
                    <!-- Property Badges -->
                    <div class="property-badges">
                      <% if (property.featured) { %>
                        <span class="badge badge-featured">Featured</span>
                      <% } %>
                      <span class="badge badge-type"><%= property.type %></span>
                    </div>
                  </div>
                  
                  <!-- Property Content -->
                  <div class="property-content">
                    <h3 class="property-title"><%= property.title %></h3>
                    
                    <div class="property-location">
                      <svg class="property-location-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                      </svg>
                      <%= property.city %>, <%= property.country %>
                    </div>
                    
                    <div class="property-specs property-details">
                      <div class="detail-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                          <circle cx="8.5" cy="8.5" r="1.5"></circle>
                          <polyline points="21,15 16,10 5,21"></polyline>
                        </svg>
                        <span><%= property.size || 0 %> m²</span>
                      </div>
                      <div class="detail-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                          <polyline points="9,22 9,12 15,12 15,22"></polyline>
                        </svg>
                        <span><%= property.bedrooms || 0 %></span>
                      </div>
                      <div class="detail-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                          <path d="M4 10h16"></path>
                        </svg>
                        <span><%= property.bathrooms || 0 %></span>
                      </div>
                    </div>
                    
                    <div class="property-price">
                       <span class="price-amount">€<%= Number(property.price || 0).toLocaleString('en-US') %></span>
                    </div>
                    
                    <div class="property-footer property-footer--actions">
                      <button type="button" class="btn-compare" onclick="event.preventDefault(); event.stopPropagation(); compareProperty('<%= property.id %>')">Compare</button>
                      <span class="btn-view-property">View Property</span>
                    </div>
                  </div>
                </a>
              <% }); %>
            </div>
            
            <!-- Map View Container -->
            <div id="mapContainer" class="map-container" style="display: none;">
              <div class="map-header">
                <h3>Property Map View</h3>
                <p>Click on map markers to view property details</p>
              </div>
              <div id="propertyMap" class="property-map">
                <!-- Map will be loaded here -->
                <div class="map-loading">
                  <div class="map-loading-spinner"></div>
                  <p>Loading map...</p>
                </div>
              </div>
            </div>
            
            <!-- Pagination -->
            <% if (totalPages > 1) { %>
              <div class="pagination">
                <% if (currentPage > 1) { %>
                  <a href="?<%= toQueryString(buildQueryParams({ page: currentPage - 1 })) %>" class="page-link">Previous</a>
                <% } %>
                
                <% for (let i = 1; i <= totalPages; i++) { %>
                  <% if (i === currentPage) { %>
                    <span class="page-link active"><%= i %></span>
                  <% } else if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                    <a href="?<%= toQueryString(buildQueryParams({ page: i })) %>" class="page-link"><%= i %></a>
                  <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                    <span class="page-link pagination-ellipsis">...</span>
                  <% } %>
                <% } %>
                
                <% if (currentPage < totalPages) { %>
                  <a href="?<%= toQueryString(buildQueryParams({ page: currentPage + 1 })) %>" class="page-link">Next</a>
                <% } %>
              </div>
            <% } %>
            
          <% } else { %>
            <div class="no-results">
              <div class="no-results-icon">🏠</div>
              <h3>No Properties Found</h3>
              <p>Try adjusting your search criteria or browse all available properties.</p>
              <div class="no-results-actions">
                <button class="btn btn-secondary" onclick="clearAllFilters()">Clear Filters</button>
                <a href="/properties" class="btn btn-primary">Browse All Properties</a>
              </div>
            </div>
          <% } %>
        </div>
      </main>
    </div>
  </div>
</div>

<!-- Property Comparison Modal -->
<div id="comparisonModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Property Comparison</h3>
      <button class="modal-close" onclick="closeComparisonModal()">&times;</button>
    </div>
    <div class="modal-body">
      <div id="comparisonContent">
        <!-- Comparison content will be loaded here -->
      </div>
    </div>
  </div>
</div>

<!-- Save Search Modal -->
<div id="saveSearchModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Save Search</h3>
      <button class="modal-close" onclick="closeSaveSearchModal()">&times;</button>
    </div>
    <div class="modal-body">
      <form id="saveSearchForm" class="save-search-form">
        <div class="form-group">
          <label for="searchName">Search Name</label>
          <input type="text" id="searchName" name="searchName" placeholder="e.g., 3-bedroom apartments in Madrid" required class="form-input">
        </div>
        <div class="form-group">
          <label for="searchDescription">Description (optional)</label>
          <textarea id="searchDescription" name="searchDescription" placeholder="Add a description to help you remember this search..." class="form-input" rows="3"></textarea>
        </div>
        <div class="form-group">
          <label class="checkbox-label">
            <input type="checkbox" id="emailAlerts" name="emailAlerts">
            <span class="checkmark"></span>
            Receive email alerts for new properties matching this search
          </label>
        </div>
        <div class="form-actions">
          <button type="button" class="btn btn-secondary" onclick="closeSaveSearchModal()">Cancel</button>
          <button type="submit" class="btn btn-primary">Save Search</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Saved Searches Modal -->
<div id="savedSearchesModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Saved Searches</h3>
      <button class="modal-close" onclick="closeSavedSearchesModal()">&times;</button>
    </div>
    <div class="modal-body">
      <div id="savedSearchesContent">
        <!-- Saved searches will be loaded here -->
      </div>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/js/property-list.js"></script>
