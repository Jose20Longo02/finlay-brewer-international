<% title = property.title; headPartial = '../partials/seo/property-detail-head'; %>
<link rel="stylesheet" href="/css/property-detail.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="property-detail-page">
  <!-- Data payload for JS -->
  <div id="propertyData"
       data-id="<%= property.id %>"
       data-slug="<%= property.slug %>"
       data-title="<%= property.title %>"
       data-country="<%= property.country %>"
       data-city="<%= property.city %>"
       data-neighborhood="<%= property.neighborhood || '' %>"
       data-map-link="<%= property.map_link || '' %>"
       data-latitude="<%= property.latitude || '' %>"
       data-longitude="<%= property.longitude || '' %>"
       data-photos="<%= encodeURIComponent(JSON.stringify(property.photos || [])) %>"></div>

  <div class="container">
    <!-- Property Header: title, location, price, social -->
    <header class="property-header">
      <div class="property-header-left">
        <h1 class="property-title"><%= property.title %></h1>
        <div class="property-location">
          <svg class="pin-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          <%= property.neighborhood ? property.neighborhood + ', ' : '' %><%= property.city %>, <%= property.country %>
        </div>
        <div class="property-price">€<%= Number(property.price || 0).toLocaleString('en-US', { minimumFractionDigits: 2 }) %></div>
      </div>
      <div class="property-social">
        <a href="#" class="social-link" aria-label="Share on Instagram" onclick="shareOnSocial('instagram'); return false;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="url(#ig)"><defs><linearGradient id="ig" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#f09433"/><stop offset="25%" style="stop-color:#e6683c"/><stop offset="50%" style="stop-color:#dc2743"/><stop offset="75%" style="stop-color:#cc2366"/><stop offset="100%" style="stop-color:#bc1888"/></linearGradient></defs><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href="#" class="social-link" aria-label="Share on Facebook" onclick="shareOnSocial('facebook'); return false;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="#1877f2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="#" class="social-link" aria-label="Share on WhatsApp" onclick="shareOnSocial('whatsapp'); return false;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="#25d366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
        <a href="#" class="social-link social-email" aria-label="Share by Email" onclick="shareByEmail(); return false;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </a>
      </div>
    </header>
    <div class="property-header-sep"></div>

    <!-- Two-column layout: gallery, characteristics, description, contact form -->
    <div class="property-content">
        <!-- Image carousel: thumbnails left, main photo right -->
        <section class="photo-gallery property-content-gallery">
          <% const galleryPhotos = (property.photos && property.photos.length > 0) ? property.photos : ['/img/property-placeholder.jpg']; %>
          <div class="gallery-layout">
            <% if (galleryPhotos.length > 1) { %>
            <div class="gallery-thumbs" id="galleryThumbs" aria-label="Photo thumbnails">
              <% galleryPhotos.forEach((photo, i) => { %>
              <button type="button" class="gallery-thumb<%= i === 0 ? ' is-active' : '' %>" data-index="<%= i %>" aria-label="View photo <%= i + 1 %>">
                <img src="<%= photo %>" alt="" loading="lazy" decoding="async" onerror="this.src='/img/property-placeholder.jpg'">
              </button>
              <% }); %>
            </div>
            <% } %>
            <div class="gallery-main">
              <div class="main-photo" id="mainPhoto">
                <img src="<%= galleryPhotos[0] %>" alt="<%= property.title %>" id="mainPhotoImg"
                     loading="lazy" decoding="async" fetchpriority="high">
                <div class="photo-overlay">
                  <button class="gallery-nav prev" onclick="previousPhoto()" aria-label="Previous photo">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="15,18 9,12 15,6"></polyline>
                    </svg>
                  </button>
                  <button class="gallery-nav next" onclick="nextPhoto()" aria-label="Next photo">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="9,18 15,12 9,6"></polyline>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </div>
          <div class="gallery-pagination" id="galleryPagination">
            <span id="currentPhotoNum">1</span> of <span id="totalPhotos"><%= galleryPhotos.length %></span>
          </div>
        </section>

        <!-- Characteristics card -->
        <div class="characteristics-card property-content-chars">
          <h3 class="characteristics-heading">Characteristics</h3>
          <ul class="characteristics-list">
            <li>
              <svg class="char-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><rect x="7" y="7" width="4" height="4"></rect><rect x="13" y="7" width="4" height="4"></rect><rect x="7" y="13" width="4" height="4"></rect><rect x="13" y="13" width="4" height="4"></rect></svg>
              <span><%= property.size ? property.size + ' m2 of living space' : '—' %></span>
            </li>
            <li>
              <svg class="char-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9,22 9,12 15,12 15,22"></polyline></svg>
              <span><%= property.bedrooms || '—' %> Bedroom<%= property.bedrooms !== 1 ? 's' : '' %></span>
            </li>
            <li>
              <svg class="char-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><path d="M4 10h16"></path></svg>
              <span><%= property.bathrooms || '—' %> Bathroom<%= property.bathrooms !== 1 ? 's' : '' %></span>
            </li>
            <% if (property.year_built) { %>
            <li>
              <svg class="char-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
              <span>Built in <%= property.year_built %></span>
            </li>
            <% } %>
            <% if (property.energy_class && ['Apartment','House','Villa'].includes(property.type)) { %>
            <li>
              <svg class="char-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path></svg>
              <span>Energy class: <%= property.energy_class %></span>
            </li>
            <% } %>
            <% if (property.property_tax != null && property.property_tax !== '') { %>
            <li>
              <svg class="char-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect><line x1="1" y1="10" x2="23" y2="10"></line><path d="M12 15h4"></path></svg>
              <span>Property tax: €<%= Number(property.property_tax).toLocaleString('en-US', { minimumFractionDigits: 2 }) %>/yr</span>
            </li>
            <% } %>
            <% if (property.characteristics && property.characteristics.length && (propertyCharacteristics || []).length) { %>
              <% const charMap = {}; (propertyCharacteristics || []).forEach(c => { charMap[c.slug] = c.label; }); %>
              <% property.characteristics.forEach(function(slug) { const label = charMap[slug]; if (!label) return; %>
            <li>
              <svg class="char-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <span><%= label %></span>
            </li>
              <% }); %>
            <% } %>
            <% if (property.parking != null && property.parking > 0 && ['Apartment','House','Villa'].includes(property.type)) { %>
            <li>
              <svg class="char-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
              <span>Parking for <%= property.parking %> car<%= property.parking !== 1 ? 's' : '' %></span>
            </li>
            <% } %>
          </ul>
        </div>

        <!-- Description -->
        <section class="property-description property-content-desc">
          <h2 class="description-heading">Description of the property</h2>
          <div class="description-content">
            <p><%= property.description || 'No description available for this property.' %></p>
          </div>
        </section>

        <% const hasCoords = property.latitude != null && property.longitude != null && property.latitude !== '' && property.longitude !== ''; %>
        <% if (hasCoords) { %>
        <!-- Location map (only when coordinates are set) -->
        <section class="property-detail-map-section property-content-desc" aria-label="Property location map">
          <h2 class="property-detail-map-heading">Location</h2>
          <div id="propertyDetailMap" class="property-detail-map" data-lat="<%= property.latitude %>" data-lng="<%= property.longitude %>"></div>
        </section>
        <% } %>

        <!-- Contact form -->
        <form id="contactForm" class="contact-form-inline property-content-form">
          <div class="form-group">
            <input type="text" id="contactName" name="name" required class="form-input" placeholder="Full name*">
          </div>
          <div class="form-group">
            <input type="tel" id="contactPhone" name="phone" required class="form-input" placeholder="Phone number*">
          </div>
          <div class="form-group">
            <input type="email" id="contactEmail" name="email" required class="form-input" placeholder="Email Address*">
          </div>
          <div class="form-group">
            <select id="contactLanguage" name="language" class="form-input form-select" required>
              <option value="">Preferred language*</option>
              <option value="en">English</option>
              <option value="fr">French</option>
            </select>
          </div>
          <div class="form-group">
            <textarea id="contactMessage" name="message" rows="4" required class="form-input" placeholder="Message*"></textarea>
          </div>
          <button type="submit" class="btn-send">Send</button>
        </form>
    </div>
  </div>

  <!-- Similar Properties (full width) -->
  <section class="similar-properties-section">
    <div class="container">
      <h2 class="similar-properties-heading">Similar Properties</h2>
      <div class="similar-carousel-wrapper">
        <button class="similar-carousel-prev" aria-label="Previous" type="button">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15,18 9,12 15,6"></polyline></svg>
        </button>
        <div class="similar-carousel" id="similarCarousel">
          <div class="similar-list" id="similarProperties">
            <div class="loading-placeholder">
              <div class="placeholder-image"></div>
              <div class="placeholder-content">
                <div class="placeholder-title"></div>
                <div class="placeholder-specs"></div>
              </div>
            </div>
          </div>
        </div>
        <button class="similar-carousel-next" aria-label="Next" type="button">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9,18 15,12 9,6"></polyline></svg>
        </button>
      </div>
    </div>
  </section>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/js/property-detail.js"></script>
