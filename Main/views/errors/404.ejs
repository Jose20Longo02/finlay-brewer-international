<% title = 'Page not found' %>
<section class="error-page">
  <h1>404</h1>
  <p>Page not found. The link may be broken or the page may have been removed.</p>
  <a href="/" class="btn">Back to home</a>
</section>
<style>
  .error-page { text-align: center; padding: 3rem 1rem; }
  .error-page h1 { font-size: 4rem; margin: 0 0 0.5rem; color: var(--color-primary, #333); }
  .error-page p { color: #666; margin-bottom: 1.5rem; }
  .error-page .btn { display: inline-block; padding: 0.5rem 1.5rem; background: var(--color-primary, #333); color: #fff; text-decoration: none; border-radius: 4px; }
  .error-page .btn:hover { opacity: 0.9; }
</style>
