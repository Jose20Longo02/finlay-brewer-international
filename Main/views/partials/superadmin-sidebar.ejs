<!-- views/partials/superadmin-sidebar.ejs -->
<link rel="stylesheet" href="/css/superadmin/superadmin-sidebar.css" />
<button class="mobile-nav-toggle" aria-controls="superadmin-sidebar" aria-expanded="false" type="button">
  ☰ Menu
  <% if (pendingCount > 0) { %>
    <span class="badge"><%= pendingCount %></span>
  <% } %>
 </button>
<aside id="superadmin-sidebar" class="admin-sidebar" aria-hidden="true">
  <ul>
    <li class="<%= activePage==='dashboard' ? 'active' : '' %>">
      <a href="/superadmin/dashboard">Dashboard</a>
    </li>
    <li class="<%= activePage==='profile' ? 'active' : '' %>">
      <a href="/superadmin/dashboard/profile">Edit Profile</a>
    </li>
    <li class="<%= activePage==='properties' ? 'active' : '' %>">
      <a href="/superadmin/dashboard/properties">Properties</a>
    </li>
    <li class="<%= activePage==='team' ? 'active' : '' %>">
      <a href="/superadmin/dashboard/team">Team</a>
    </li>
    <li class="<%= activePage==='leads' ? 'active' : '' %>">
      <a href="/superadmin/dashboard/leads">Leads</a>
    </li>
    <li class="<%= activePage==='requests' ? 'active' : '' %>">
      <a href="/superadmin/dashboard/requests">
        Requests
        <% if (pendingCount > 0) { %>
          <span class="badge"><%= pendingCount %></span>
        <% } %>
      </a>
    </li>
    <li class="<%= activePage==='blogs' ? 'active' : '' %>">
      <a href="/superadmin/dashboard/blogs">Blog</a>
    </li>
    <li class="<%= activePage==='buyers' ? 'active' : '' %>">
      <a href="/superadmin/dashboard/buyers">Our Buyers</a>
    </li>

    <li class="logout">
      <form action="/auth/logout" method="post">
        <button type="submit" class="logout-btn">Log Out</button>
      </form>
    </li>
  </ul>
</aside>
<div class="admin-overlay" data-close-sidebar></div>