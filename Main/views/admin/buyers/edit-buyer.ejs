<% title = 'Edit buyer' %>
<link rel="stylesheet" href="/css/admin/new-property.css" />
<link rel="stylesheet" href="/css/admin/buyer-form.css" />

<% 
  const basePath = isSuperAdmin ? '/superadmin/dashboard/buyers' : '/admin/dashboard/buyers';
  const backUrl = basePath;
%>

<% if (isSuperAdmin) { %>
<div class="admin-panel">
  <div class="admin-body">
    <%- include('../../partials/superadmin-sidebar', { activePage: 'buyers', pendingCount: pendingCount || 0 }) %>
    <main class="admin-content">
<% } %>
<div class="new-prop-page buyer-form-page">
  <header class="np-header">
    <h1>Edit buyer</h1>
    <p class="np-subtitle">Update contact and property interests.</p>
    <a href="<%= backUrl %>" class="btn btn-light">Cancel</a>
  </header>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

  <form class="np-form" method="post" action="<%= basePath %>/<%= buyer.id %>">
    <section class="np-card">
      <h2 class="np-card-title">Contact</h2>
      <div class="grid-3">
        <div class="field">
          <label for="name">Name<span class="req">*</span></label>
          <input id="name" name="name" type="text" required value="<%= buyer.name %>" />
        </div>
        <div class="field">
          <label for="email">Email<span class="req">*</span></label>
          <input id="email" name="email" type="email" required value="<%= buyer.email %>" />
        </div>
        <div class="field">
          <label for="phone">Phone</label>
          <input id="phone" name="phone" type="tel" value="<%= buyer.phone || '' %>" />
        </div>
      </div>
    </section>

    <section class="np-card">
      <h2 class="np-card-title">Property interests</h2>
      <p class="np-subtitle" style="margin-bottom: 1rem;">Criteria for matching properties. Leave empty for “any”. Select countries first — cities will filter accordingly.</p>
      <div class="buyer-interests-grid">
        <% 
          let cityToCountry = {};
          if (typeof countryToCities === 'object') {
            for (const [country, cities] of Object.entries(countryToCities)) {
              for (const city of (cities || [])) cityToCountry[city] = country;
            }
          }
          const buildingOnlyKeys = ['min_bedrooms', 'min_bathrooms'];
          const livingSpaceKeys = ['min_size', 'max_size'];
          const landSizeKeys = ['min_land_size', 'max_land_size'];
        %>
        <% (schema || []).forEach(function(field) { %>
          <% if (field.type === 'multi-select') { %>
            <div class="field buyer-field-multi" data-buyer-field="<%= field.key %>">
              <label><%= field.label %></label>
              <div class="chips">
                <% 
                  const opts = field.options || [];
                  const current = (interests && interests[field.key]) || [];
                  const currentArr = Array.isArray(current) ? current : [current];
                %>
                <% opts.forEach(function(opt) {
                  const val = typeof opt === 'object' ? opt.value : opt;
                  const lab = typeof opt === 'object' ? opt.label : opt;
                %>
                  <label class="chip"<%= field.key === 'cities' ? ' data-city-country="' + (cityToCountry[val] || '') + '"' : '' %>>
                    <input type="checkbox" name="<%= field.key %>" value="<%= val %>" <%= currentArr.includes(val) ? 'checked' : '' %> />
                    <span><%= lab %></span>
                  </label>
                <% }); %>
              </div>
            </div>
          <% } else if (field.type === 'number') { %>
            <div class="field" data-buyer-field="<%= field.key %>"<%= buildingOnlyKeys.includes(field.key) ? ' data-buyer-building-only' : '' %><%= livingSpaceKeys.includes(field.key) ? ' data-buyer-living-space' : '' %><%= landSizeKeys.includes(field.key) ? ' data-buyer-land-size' : '' %>>
              <label for="int-<%= field.key %>"><%= field.label %></label>
              <input id="int-<%= field.key %>" name="<%= field.key %>" type="number" min="0" step="<%= field.key.includes('price') ? '1000' : '1' %>" 
                     value="<%= (interests && interests[field.key]) || '' %>" />
            </div>
          <% } %>
        <% }); %>
      </div>
    </section>

    <div class="np-form-actions">
      <a href="<%= backUrl %>" class="btn btn-light">Cancel</a>
      <button type="submit" class="btn btn-primary">Save changes</button>
    </div>
  </form>
</div>
<% if (isSuperAdmin) { %>
    </main>
  </div>
</div>
<% } %>

<script>
(function() {
  const countryToCities = <%- JSON.stringify(countryToCities || {}) %>;
  const cityChips = () => document.querySelectorAll('[data-buyer-field="cities"] .chip');
  const countryInputs = () => document.querySelectorAll('[data-buyer-field="countries"] input[name="countries"]');
  const typeInputs = () => document.querySelectorAll('[data-buyer-field="types"] input[name="types"]');
  const buildingOnlyFields = () => document.querySelectorAll('[data-buyer-building-only]');
  const livingSpaceFields = () => document.querySelectorAll('[data-buyer-living-space]');
  const landSizeFields = () => document.querySelectorAll('[data-buyer-land-size]');

  function filterCities() {
    const selected = Array.from(countryInputs()).filter(i => i.checked).map(i => i.value);
    const allowed = new Set();
    selected.forEach(c => (countryToCities[c] || []).forEach(ct => allowed.add(ct)));
    cityChips().forEach(chip => {
      const input = chip.querySelector('input');
      if (!input) return;
      const city = input.value;
      if (selected.length === 0) chip.style.display = '';
      else if (allowed.has(city)) chip.style.display = '';
      else { chip.style.display = 'none'; input.checked = false; }
    });
  }

  function updateSizeFields() {
    const selected = Array.from(typeInputs()).filter(i => i.checked).map(i => i.value);
    const onlyLand = selected.length > 0 && selected.every(t => t === 'Land');
    const onlyApartment = selected.length > 0 && selected.every(t => t === 'Apartment');
    buildingOnlyFields().forEach(el => {
      el.style.display = onlyLand ? 'none' : '';
      if (onlyLand) { const inp = el.querySelector('input'); if (inp) inp.value = ''; }
    });
    livingSpaceFields().forEach(el => {
      el.style.display = onlyLand ? 'none' : '';
      if (onlyLand) { const inp = el.querySelector('input'); if (inp) inp.value = ''; }
    });
    landSizeFields().forEach(el => {
      el.style.display = onlyApartment ? 'none' : '';
      if (onlyApartment) { const inp = el.querySelector('input'); if (inp) inp.value = ''; }
    });
  }

  function init() {
    countryInputs().forEach(i => i.addEventListener('change', filterCities));
    typeInputs().forEach(i => i.addEventListener('change', updateSizeFields));
    filterCities();
    updateSizeFields();
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
