<% title = 'New Blog Post' %>
<link rel="stylesheet" href="/css/admin/new-property.css" />
<link rel="stylesheet" href="/css/admin/blog-form.css" />
<script src="https://cdn.tiny.cloud/1/<%= tinymceKey %>/tinymce/7/tinymce.min.js" referrerpolicy="origin"></script>

<% 
  const backUrl = currentUser && currentUser.role === 'SuperAdmin' 
    ? '/superadmin/dashboard/blogs' 
    : '/admin/dashboard/blogs';
  const uploadPath = currentUser && currentUser.role === 'SuperAdmin' 
    ? '/superadmin/dashboard/blogs/upload-image' 
    : '/admin/dashboard/blogs/upload-image';
%>

<div class="new-prop-page blog-form-page">
  <header class="np-header">
    <h1>Create new blog post</h1>
    <p class="np-subtitle">Write an article to share insights, tips, and news with your audience.</p>
    <a href="<%= backUrl %>" class="btn btn-light">Cancel</a>
  </header>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form class="np-form blog-form" method="post" enctype="multipart/form-data">
    <section class="np-card">
      <h2 class="np-card-title">Basics</h2>
      <div class="field">
        <label for="title">Title<span class="req">*</span></label>
        <input id="title" name="title" type="text" maxlength="255" required 
               placeholder="Enter a compelling headline" 
               value="<%= (form && form.title) || '' %>" />
      </div>
      <div class="field">
        <label for="slug">URL slug</label>
        <input id="slug" name="slug" type="text" maxlength="255" 
               placeholder="Leave empty to auto-generate from title (e.g. my-article-title)" 
               value="<%= (form && form.slug) || '' %>" />
        <small>Optional. Used in the URL: /blog/your-slug</small>
      </div>
      <div class="field">
        <label for="excerpt">Excerpt</label>
        <textarea id="excerpt" name="excerpt" rows="3" maxlength="500"
                  placeholder="Short summary for cards and SEO (recommended 120–160 characters)"><%= (form && form.excerpt) || '' %></textarea>
        <small>Shown on the blog listing and search results.</small>
      </div>
    </section>

    <section class="np-card">
      <h2 class="np-card-title">Cover image</h2>
      <div class="field">
        <label for="cover_image">Cover image</label>
        <input id="cover_image" name="cover_image" type="file" accept="image/*" />
        <small>Recommended: 1200×630px, max 5MB. JPG, PNG, or WebP.</small>
      </div>
    </section>

    <section class="np-card">
      <h2 class="np-card-title">Content</h2>
      <div class="field">
        <label for="content">Body<span class="req">*</span></label>
        <textarea id="content" name="content" rows="16" required
                  placeholder="Write your article with rich formatting."><%= (form && form.content) || '' %></textarea>
        <small>Use headings, images, colors, and full formatting. Images can be pasted or uploaded.</small>
      </div>
    </section>

    <div class="np-form-actions">
      <a href="<%= backUrl %>" class="btn btn-light">Cancel</a>
      <button type="submit" class="btn btn-primary">Publish post</button>
    </div>
  </form>
</div>

<script>
  tinymce.init({
    selector: '#content',
    height: 420,
    menubar: true,
    plugins: 'anchor autolink charmap codesample emoticons image link lists media searchreplace table visualblocks wordcount',
    toolbar: 'undo redo | blocks fontsize | bold italic underline strikethrough | forecolor backcolor | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | link image media table | removeformat',
    block_formats: 'Paragraph=p; Heading 1=h1; Heading 2=h2; Heading 3=h3; Heading 4=h4',
    fontsize_formats: '12px 14px 16px 18px 24px 32px',
    content_style: 'body { font-family: inherit; font-size: 16px; }',
    images_upload_url: '<%= uploadPath %>',
    automatic_uploads: true,
    images_upload_credentials: false,
    file_picker_types: 'image',
    relative_urls: false,
    remove_script_host: false,
    promotion: false,
    branding: false
  });
</script>
