<% title = 'Find Your Dream Home' %>
<%
  const heroDestinations = [
    { id: 'france', label: 'France', country: 'France' },
    { id: 'monaco', label: 'Monaco', country: 'Monaco' },
    { id: 'montenegro', label: 'Montenegro', country: 'Montenegro' },
    { id: 'costa-del-sol', label: 'Costa Del Sol', country: 'Spain' },
    { id: 'london', label: 'London', country: 'UK' }
  ];
  const locationCountries = Object.keys(locations || {});
  const heroCountries = heroDestinations.map(d => d.country);
  const allCountries = [...new Set([...locationCountries, ...heroCountries])].sort();
%>
<link rel="stylesheet" href="/css/home.css" />

<script>
  window.locationsData = <%- JSON.stringify(locations) %>;
  window.heroDestinations = <%- JSON.stringify(heroDestinations) %>;
</script>

<!-- Hero Section (design: coastal background + search bar + destination tabs) -->
<section class="hero" id="hero">
  <div class="hero-backgrounds">
    <% heroDestinations.forEach((dest, i) => { %>
    <div class="hero-bg <%= i === 0 ? 'active' : '' %>" data-destination="<%= dest.id %>"></div>
    <% }); %>
  </div>
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="search-container">
      <div class="search-bar-top"></div>
      <form class="search-form" action="/properties" method="GET">
        <div class="search-row">
          <div class="search-field-inline">
            <label for="hero-country">Location:</label>
            <select id="hero-country" name="country">
              <option value="">Any</option>
              <% allCountries.forEach(country => { %>
                <option value="<%= country %>"><%= country %></option>
              <% }); %>
            </select>
          </div>
          <div class="search-field-inline">
            <label for="hero-operation">Operation:</label>
            <select id="hero-operation" name="operation">
              <option value="">Any</option>
              <option value="sale">Buy</option>
              <option value="rent">Rent</option>
            </select>
          </div>
          <div class="search-field-inline">
            <label for="hero-type">Type:</label>
            <select id="hero-type" name="type">
              <option value="">Any Type</option>
              <option value="Apartment">Apartment</option>
              <option value="House">House</option>
              <option value="Villa">Villa</option>
              <option value="Land">Land</option>
            </select>
          </div>
        </div>
        <button type="submit" class="search-btn-hero">Search</button>
      </form>
    </div>
  </div>

  <div class="hero-destinations">
    <div class="hero-tabs" role="tablist">
      <span class="hero-tabs-line" aria-hidden="true"></span>
      <span class="hero-tab-indicator" aria-hidden="true"></span>
      <% heroDestinations.forEach((dest, i) => { %>
      <span class="hero-tab <%= i === 0 ? 'active' : '' %>" data-destination="<%= dest.id %>" data-country="<%= dest.country %>"><a href="<%= dest.country === 'UK' ? 'https://www.finlaybrewer.co.uk/' : '/properties?country=' + encodeURIComponent(dest.country) %>"><%= dest.label %></a></span>
      <% }); %>
    </div>
  </div>
</section>

<div class="container">

<% const fp = typeof featuredProperties !== 'undefined' ? featuredProperties : []; %>
<% if (fp.length >= 5) { %>
<!-- Our Favorite Properties Section -->
<section class="favorite-properties-section" id="favorite-properties">
  <div class="section-header-row">
    <h2>Our Favorite Properties</h2>
    <a href="/properties" class="cta-button" aria-label="View all properties">
      <span class="cta-icon" aria-hidden="true">→</span>
      <span class="cta-label">All Properties</span>
    </a>
  </div>
</section>
<!-- Carousel full-bleed (outside section padding) -->
<svg width="0" height="0" aria-hidden="true"><defs><clipPath id="cinema-curve" clipPathUnits="objectBoundingBox"><path d="M 0,0.06 Q 0.5,-0.02 1,0.06 L 1,0.94 Q 0.5,1.02 0,0.94 Z"/></clipPath></defs></svg>
<div class="gallery-strip-wrapper">
  <div class="gallery-strip" data-autoplay="true">
    <div class="gallery-track" id="favoritePropertiesTrack">
      <% fp.forEach(property => { %>
        <a href="<%= property.slug ? '/properties/' + property.slug : '/properties' %>" class="gallery-frame gallery-frame--property" data-index="<%= property.id %>">
          <div class="gallery-frame-img">
            <img src="<%= (property.photos && property.photos[0]) ? property.photos[0] : '/img/property-placeholder.jpg' %>" 
                 alt="<%= property.title %>" loading="lazy" decoding="async"
                 onerror="this.src='/img/property-placeholder.jpg'">
            <% if (property.type) { %>
            <span class="gallery-frame-badge"><%= property.type %></span>
            <% } %>
          </div>
          <div class="gallery-frame-content">
            <h3 class="gallery-frame-title"><%= property.title %></h3>
            <div class="gallery-frame-meta">
              <svg class="gallery-frame-pin" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              <%= property.city %>, <%= property.country %>
            </div>
            <div class="gallery-frame-footer">
              <span class="gallery-frame-price">€<%= Number(property.price).toLocaleString('en-US', { maximumFractionDigits: 0 }) %></span>
              <span class="gallery-frame-cta">View details →</span>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  </div>
</div>
<% } %>

<!-- About Finlay Brewer International Section -->
<section class="about-section" id="about">
  <div class="about-section-bg" style="background-image: url('/img/French-riviera-about-section-home-page.jpg');" aria-hidden="true"></div>
  <div class="about-section-overlay" aria-hidden="true"></div>
  <div class="about-section-content">
    <h2 class="about-section-title">About Finlay Brewer<br>International</h2>
    <p class="about-section-text">Lorem ipsum dolor sit amet consectetur. Morbi senectus egestas ipsum id purus sit vivamus amet. Est pulvinar at dignissim elementum ut. Aliquet ullamcorper mattis eu etiam id tempor facilisis urna enim. Blandit varius elementum et faucibus duis magna laoreet mauris. Mattis fames eleifend nulla.</p>
    <a href="/properties" class="cta-button cta-button--white" aria-label="Learn more about us">
      <span class="cta-icon" aria-hidden="true">→</span>
      <span class="cta-label">Learn More</span>
    </a>
  </div>
</section>

<!-- Mortgage Calculator Section -->
<section class="mortgage-calculator">
    <div class="section-header text-center">
      <h2>Mortgage Calculator</h2>
      <p>Calculate your monthly mortgage payments and understand your financing options</p>
    </div>
    
    <div class="calculator-container">
      <div class="calculator-form" id="calculatorForm">
        <div class="form-row">
          <div class="form-group">
            <label for="propertyPrice">Property Price (€)</label>
            <input type="number" id="propertyPrice" placeholder="500,000" min="0" step="1000">
          </div>
          <div class="form-group">
            <label for="downPayment">Down Payment (€)</label>
            <input type="number" id="downPayment" placeholder="100,000" min="0" step="1000">
          </div>
        </div>
        
        <div class="form-row">
          <div class="form-group">
            <label for="loanTerm">Loan Term (Years)</label>
            <select id="loanTerm">
              <option value="15">15 Years</option>
              <option value="20">20 Years</option>
              <option value="25">25 Years</option>
              <option value="30" selected>30 Years</option>
            </select>
          </div>
          <div class="form-group">
            <label for="interestRate">Interest Rate (%)</label>
            <input type="number" id="interestRate" placeholder="3.5" min="0" max="20" step="0.1">
          </div>
        </div>
        
        <button type="button" class="btn btn-primary btn-lg" onclick="calculateMortgage()">
          Calculate Payment
        </button>
      </div>
      
      <div class="calculator-results" id="calculatorResults">
        <h3>Your Monthly Payment</h3>
        <div class="payment-breakdown">
          <div class="result-item">
            <span class="result-label">Principal & Interest:</span>
            <span class="result-value" id="monthlyPayment">€0</span>
          </div>
          <div class="result-item">
            <span class="result-label">Property Tax (estimated):</span>
            <span class="result-value" id="propertyTax">€0</span>
          </div>
          <div class="result-item">
            <span class="result-label">Insurance (estimated):</span>
            <span class="result-value" id="insurance">€0</span>
          </div>
          <div class="result-item total">
            <span class="result-label">Total Monthly Payment:</span>
            <span class="result-value" id="totalPayment">€0</span>
          </div>
        </div>
        
        <div class="loan-summary">
          <h4>Loan Summary</h4>
          <div class="summary-grid">
            <div class="summary-item">
              <span class="summary-label">Loan Amount:</span>
              <span class="summary-value" id="loanAmount">€0</span>
            </div>
            <div class="summary-item">
              <span class="summary-label">Total Interest:</span>
              <span class="summary-value" id="totalInterest">€0</span>
            </div>
            <div class="summary-item">
              <span class="summary-label">Total Cost:</span>
              <span class="summary-value" id="totalCost">€0</span>
            </div>
          </div>
        </div>
        <div class="calculator-results-actions">
          <button type="button" class="btn btn-primary btn-lg" onclick="resetMortgageCalculator()">
            Do another calculation
          </button>
        </div>
      </div>
    </div>
</section>

<!-- Recent Articles Section -->
<section class="recent-articles-section" id="blog" aria-label="Recent articles">
  <div class="recent-articles-inner">
    <div class="recent-articles-content">
      <h2 class="recent-articles-title">Recent Articles</h2>
      <p class="recent-articles-text">Lorem ipsum dolor sit amet consectetur. Morbi senectus egestas ipsum id purus sit vivamus amet. Est pulvinar at dignissim elementum ut. Aliquet ullamcorper mattis eu etiam id tempor facilisis urna enim. Blandit varius elementum et faucibus duis magna laoreet mauris. Mattis fames eleifend nulla.</p>
      <p class="recent-articles-text">Lorem ipsum dolor sit amet consectetur. Morbi senectus egestas ipsum id purus sit vivamus amet. Est pulvinar at dignissim elementum ut.</p>
      <a href="/blog" class="cta-button" aria-label="Visit blog">
        <span class="cta-icon" aria-hidden="true">→</span>
        <span class="cta-label">Visit Blog</span>
      </a>
    </div>
    <div class="recent-articles-carousel-wrapper">
      <div class="recent-articles-carousel" id="articlesCarousel">
        <% const articles = typeof recentArticles !== 'undefined' && Array.isArray(recentArticles) ? recentArticles : []; %>
        <% const posMap = ['pos-0', 'pos-1', 'pos-2', 'pos-3', 'pos-4']; %>
        <% if (articles.length === 0) { %>
          <% for (var i = 0; i < 5; i++) { %>
            <a href="#" class="article-card <%= posMap[i] || '' %>" data-index="<%= i %>">
              <div class="article-card-bg" style="background-image: url('/img/France.jpg');"></div>
              <div class="article-card-overlay">
                <h3 class="article-card-title">Placeholder Article <%= i + 1 %></h3>
                <span class="article-card-link">Read Article</span>
              </div>
            </a>
          <% } %>
        <% } else { %>
          <% articles.forEach((article, i) => { %>
            <a href="<%= article.slug ? '/blog/' + article.slug : '#' %>" class="article-card <%= posMap[i] || '' %>" data-index="<%= i %>">
              <div class="article-card-bg" style="background-image: url('<%= article.cover_image || '/img/property-placeholder.jpg' %>');"></div>
              <div class="article-card-overlay">
                <h3 class="article-card-title"><%= article.title %></h3>
                <span class="article-card-link">Read Article</span>
              </div>
            </a>
          <% }); %>
        <% } %>
      </div>
      <div class="recent-articles-nav">
        <button type="button" class="articles-nav-btn articles-nav-prev" aria-label="Previous article">‹</button>
        <button type="button" class="articles-nav-btn articles-nav-next" aria-label="Next article">›</button>
      </div>
    </div>
  </div>
</section>

<!-- Contact Us Section -->
<section class="contact-section" id="contact">
  <h2 class="contact-section-title">Contact Us</h2>
  <div class="contact-inner">
    <div class="contact-office-card" id="contactOfficeCard">
      <div class="contact-office-bg" style="background-image: url('/img/london-office.jpg');"></div>
      <div class="contact-office-overlay">
        <h3 class="contact-office-heading">Our Office</h3>
        <p class="contact-office-text">Office Addresse</p>
        <p class="contact-office-phone">+49-030 65852933</p>
      </div>
    </div>
    <form class="contact-form" id="homeContactForm" method="post">
      <input type="text" name="name" placeholder="Full name*" required class="contact-input">
      <input type="tel" name="phone" placeholder="Phone number*" required class="contact-input">
      <input type="email" name="email" placeholder="Email Address*" required class="contact-input">
      <select name="language" required class="contact-input contact-select">
        <option value="">Preferred language*</option>
        <option value="en">English</option>
        <option value="es">Spanish</option>
        <option value="fr">French</option>
        <option value="de">German</option>
        <option value="it">Italian</option>
      </select>
      <textarea name="message" placeholder="Message" rows="4" class="contact-input contact-textarea"></textarea>
      <button type="submit" class="contact-submit">Send</button>
    </form>
  </div>
</section>

</div><!-- /.container -->

<script src="/js/home.js"></script>
