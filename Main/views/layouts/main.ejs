<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | RealEstatePlatform</title>
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="/css/variables.css" />
  <link rel="stylesheet" href="/css/admin-theme.css" />
  <% if (typeof bodyClass !== 'undefined' && bodyClass.indexOf('page-blog') !== -1) { %><link rel="stylesheet" href="/css/blog.css" /><% } %>
  <% if (typeof loadLoginCss !== 'undefined' && loadLoginCss) { %><link rel="stylesheet" href="/css/auth/login.css" /><% } %>
  <% if (typeof loadRegisterCss !== 'undefined' && loadRegisterCss) { %><link rel="stylesheet" href="/css/auth/register.css" /><% } %>
  <% if (typeof headPartial !== 'undefined' && headPartial) { try { %><%- include(headPartial) %><% } catch (e) { } } %>
  <script src="/js/main.js" defer></script>
</head>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <%- include('../partials/header') %>
  <main id="main-content" class="container" role="main">
    <%- body %>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>