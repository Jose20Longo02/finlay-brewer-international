<head>
  <link rel="stylesheet" href="/css/superadmin/super-admin-dashboard.css" />
</head>

<% title = 'Super Admin Dashboard' %>

<div class="admin-panel">
  <div class="admin-body">
    <%- include('../partials/superadmin-sidebar', {
      activePage: 'dashboard',
      pendingCount: pendingCount
    }) %>

    <main class="admin-content dashboard-content">
      <header class="dashboard-header">
        <h1>Dashboard</h1>
        <p class="dashboard-subtitle">
          Real-time insights and quick actions for your platform.
        </p>
      </header>

      <!-- Stats -->
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-icon" aria-hidden="true">👥</span>
          <div class="stat-content">
            <span class="stat-label">Team Members</span>
            <span class="stat-value"><%= totalTeamMembers %></span>
          </div>
        </div>
        <div class="stat-card">
          <span class="stat-icon" aria-hidden="true">⏳</span>
          <div class="stat-content">
            <span class="stat-label">Pending Approvals</span>
            <span class="stat-value"><%= pendingCount %></span>
          </div>
        </div>
        <div class="stat-card">
          <span class="stat-icon" aria-hidden="true">🏠</span>
          <div class="stat-content">
            <span class="stat-label">Total Properties</span>
            <span class="stat-value"><%= totalProperties %></span>
          </div>
        </div>
        <div class="stat-card">
          <span class="stat-icon" aria-hidden="true">📦</span>
          <div class="stat-content">
            <span class="stat-label">Total Projects</span>
            <span class="stat-value"><%= totalProjects %></span>
          </div>
        </div>
        <div class="stat-card">
          <span class="stat-icon" aria-hidden="true">✨</span>
          <div class="stat-content">
            <span class="stat-label">New Listings (7d)</span>
            <span class="stat-value"><%= newListings %></span>
          </div>
        </div>
      </div>

      <!-- Top Properties -->
      <section class="dashboard-section">
        <div class="section-header">
          <h2>Top properties</h2>
          <span class="section-badge">by views</span>
        </div>
        <% if (topProperties.length < 1) { %>
          <p class="section-empty">Not enough properties yet.</p>
        <% } else { %>
          <div class="card-carousel">
            <% topProperties.forEach(prop => { const photos = Array.isArray(prop.photos) ? prop.photos : (prop.photos ? [prop.photos] : []); %>
              <a href="/properties/<%= prop.slug || prop.id %>" class="card card--property">
                <div class="card-image">
                  <img src="<%= photos[0] || '/img/property-placeholder.png' %>" alt="" loading="lazy" />
                </div>
                <div class="card-body">
                  <h3 class="card-title"><%= prop.title %></h3>
                  <p class="card-meta"><%= prop.views %> views</p>
                </div>
              </a>
            <% }); %>
          </div>
        <% } %>
      </section>

      <!-- Top Agents -->
      <section class="dashboard-section">
        <div class="section-header">
          <h2>Top agents</h2>
          <span class="section-badge">by listings</span>
        </div>
        <% if (topAgents.length < 1) { %>
          <p class="section-empty">Not enough data yet.</p>
        <% } else { %>
          <div class="card-carousel">
            <% topAgents.forEach(agent => { %>
              <div class="card card--agent">
                <div class="card-image card-image--avatar">
                  <img src="<%= agent.profile_picture || '/img/default-avatar.png' %>" alt="" loading="lazy" />
                </div>
                <div class="card-body">
                  <h3 class="card-title"><%= agent.name %></h3>
                  <p class="card-meta"><%= agent.property_count %> listings</p>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>

      <!-- Top Places -->
      <section class="dashboard-section">
        <div class="section-header">
          <h2>Top places</h2>
          <span class="section-badge">by views</span>
        </div>
        <% if (topPlaces.length < 1) { %>
          <p class="section-empty">Not enough data yet.</p>
        <% } else { %>
          <div class="card-carousel">
            <% topPlaces.forEach(place => { %>
              <div class="card card--place">
                <div class="card-icon">📍</div>
                <div class="card-body">
                  <h3 class="card-title"><%= place.place || place.name %></h3>
                  <p class="card-meta"><%= place.total_views %> views</p>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>
    </main>
  </div>
</div>
