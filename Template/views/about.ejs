  <!-- Meet the team -->
  <section class="about-team" id="meet-the-team">
    <h2 class="fs-section-title">Meet the team</h2>
    <div class="about-team-grid">
      <div class="about-team-card">
        <div class="about-team-photo" style="background-image: url('/img/Monaco.jpg');"></div>
        <div class="about-team-info">
          <h3 class="about-team-name">Name Name</h3>
          <p class="about-team-position">Position</p>
        </div>
      </div>
      <div class="about-team-card">
        <div class="about-team-photo" style="background-image: url('/img/France.jpg');"></div>
        <div class="about-team-info">
          <h3 class="about-team-name">Name Name</h3>
          <p class="about-team-position">Position</p>
        </div>
      </div>
      <div class="about-team-card">
        <div class="about-team-photo" style="background-image: url('/img/Montenegro.jpg');"></div>
        <div class="about-team-info">
          <h3 class="about-team-name">Name Name</h3>
          <p class="about-team-position">Position</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Us -->
  <section class="fs-contact" id="about-contact">
    <h2 class="fs-section-title">Contact Us!</h2>
    <p class="fs-contact-subtitle">Get in touch and we'll respond within 24 hours.</p>
    <div class="fs-contact-form-wrap">
      <form class="fs-contact-form" id="fsContactForm" method="post">
        <div class="fs-form-row">
          <input type="text" name="firstName" placeholder="First Name" required class="fs-input">
          <input type="text" name="lastName" placeholder="Last Name" required class="fs-input">
        </div>
        <div class="fs-form-row">
          <input type="text" name="countryCode" placeholder="Country code" class="fs-input">
          <input type="tel" name="phone" placeholder="Phone Number" required class="fs-input">
        </div>
        <input type="email" name="email" placeholder="Email Address" required class="fs-input fs-input-full">
        <textarea name="message" placeholder="Message" rows="4" required class="fs-input fs-textarea"></textarea>
        <button type="submit" class="fs-submit">Submit</button>
      </form>
    </div>
  </section>
</div>

<script src="/js/for-sellers.js"></script>
