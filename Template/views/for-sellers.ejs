<% title = typeof title !== 'undefined' ? title : 'For Sellers'; %>
<link rel="stylesheet" href="/css/for-sellers.css" />

<div class="for-sellers-page">
  <!-- Hero -->
  <section class="fs-hero">
    <div class="fs-hero-bg" style="background-image: url('/img/French-riviera-for-sellers-page.jpg');"></div>
    <div class="fs-hero-overlay"></div>
    <div class="fs-hero-content">
      <h1 class="fs-hero-title">
        Sell your property         <span class="fs-hero-highlight">
          <span class="fs-hero-strut" aria-hidden="true">internationally</span>
          <span class="fs-hero-word active">internationally</span>
          <span class="fs-hero-word">professionally</span>
          <span class="fs-hero-word">successfully</span>
          <span class="fs-hero-word">effortlessly</span>
          <span class="fs-hero-word">confidently</span>
        </span>
      </h1>
      <p class="fs-hero-subtitle">Reach qualified buyers across 20+ countries through our international network.</p>
      <a href="#fs-contact" class="fs-hero-cta">Get a Free Valuation</a>
      <p class="fs-hero-trust">Trusted in 20+ countries · 500+ properties sold</p>
    </div>
  </section>

  <% if (typeof soldProperties !== 'undefined' && Array.isArray(soldProperties) && soldProperties.length >= 4) { %>
  <!-- Our results (sold properties from CMS) -->
  <section class="fs-results">
    <h2 class="fs-section-title">Our results speak from themselves</h2>
    <div class="fs-results-carousel-wrap">
      <div class="fs-results-track">
        <% const soldList = soldProperties; %>
        <% for (let loop = 0; loop < 3; loop++) { soldList.forEach((prop, i) => { const idx = loop * soldList.length + i; const imgSrc = (prop.photos && prop.photos[0]) ? prop.photos[0] : '/img/France.jpg'; const loc = [prop.neighborhood, prop.city].filter(Boolean).join(', ') || prop.city || prop.country || 'Property'; const cardLoc = loc + (prop.country && loc !== prop.country ? ', ' + prop.country : ''); %>
        <div class="fs-result-card<%= idx === 1 ? ' active' : '' %>" data-index="<%= idx %>">
          <% if (prop.slug) { %><a href="/properties/<%= prop.slug %>" class="fs-result-card-link" aria-label="View sold property: <%= prop.title || loc %>"><% } %>
          <div class="fs-result-image" style="background-image: url('<%= imgSrc %>');"></div>
          <div class="fs-result-overlay">
            <span class="fs-result-label">Recently Sold</span>
            <span class="fs-result-location"><%= cardLoc %></span>
          </div>
          <% if (prop.slug) { %></a><% } %>
        </div>
        <% }); } %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Why work with us -->
  <section class="fs-why">
    <h2 class="fs-section-title">Why work with us?</h2>
    <p class="fs-why-subtitle">We combine local expertise with global reach to deliver a seamless selling experience.</p>
    <div class="fs-why-layout">
      <div class="fs-why-content">
        <ul class="fs-why-list">
          <li><span class="fs-check"></span><span>Access to qualified buyers in 20+ countries</span></li>
          <li><span class="fs-check"></span><span>Professional photography and marketing for your property</span></li>
          <li><span class="fs-check"></span><span>Transparent process from valuation to closing</span></li>
          <li><span class="fs-check"></span><span>Dedicated support throughout the entire journey</span></li>
          <li><span class="fs-check"></span><span>Competitive fees with no hidden costs</span></li>
          <li><span class="fs-check"></span><span>Trusted by hundreds of sellers worldwide</span></li>
        </ul>
      </div>
      <div class="fs-why-image-wrap">
        <div class="fs-why-image" style="background-image: url('/img/French-riviera.jpg');"></div>
      </div>
    </div>
  </section>

  <!-- Contact Us -->
  <section class="fs-contact" id="fs-contact">
    <h2 class="fs-section-title">Contact Us</h2>
    <p class="fs-contact-subtitle">Get in touch and we'll respond within 24 hours.</p>
    <div class="fs-contact-form-wrap">
      <form class="fs-contact-form" id="fsContactForm" method="post">
      <div class="fs-form-row">
        <input type="text" name="firstName" placeholder="First Name" required class="fs-input">
        <input type="text" name="lastName" placeholder="Last Name" required class="fs-input">
      </div>
      <div class="fs-form-row">
        <input type="text" name="countryCode" placeholder="Country code" class="fs-input">
        <input type="tel" name="phone" placeholder="Phone Number" required class="fs-input">
      </div>
      <input type="email" name="email" placeholder="Email Address" required class="fs-input fs-input-full">
      <textarea name="message" placeholder="Message" rows="4" required class="fs-input fs-textarea"></textarea>
      <button type="submit" class="fs-submit">Send Message</button>
    </form>
    </div>
  </section>
</div>

<script src="/js/for-sellers.js"></script>
